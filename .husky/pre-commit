#!/bin/sh

# XIANZE Monorepo Pre-commit Hook
# Runs checks for both frontend and backend

echo "🚀 Running pre-commit checks..."
echo ""

# Check if backend files were changed
BACKEND_CHANGED=$(git diff --cached --name-only | grep "^backend/" | head -1)
# Check if frontend files were changed
FRONTEND_CHANGED=$(git diff --cached --name-only | grep "^frontend/" | head -1)

# Run backend checks if backend files were changed
if [ -n "$BACKEND_CHANGED" ]; then
  echo "📦 Backend files changed, running backend checks..."
  cd backend
  
  echo "🎨 Running Prettier format..."
  bun run format
  if [ $? -ne 0 ]; then
    echo "❌ Backend formatting failed. Commit aborted."
    exit 1
  fi
  
  echo "🔍 Running ESLint check..."
  bun run lint:check
  if [ $? -ne 0 ]; then
    echo "❌ Backend lint check failed. Commit aborted."
    exit 1
  fi
  
  echo "✅ Backend checks passed!"
  cd ..
  echo ""
fi

# Run frontend checks if frontend files were changed
if [ -n "$FRONTEND_CHANGED" ]; then
  echo "📦 Frontend files changed, running frontend checks..."
  cd frontend
  
  echo "🎨 Running Prettier format..."
  bun run format
  if [ $? -ne 0 ]; then
    echo "❌ Frontend formatting failed. Commit aborted."
    exit 1
  fi
  
  echo "🔍 Running ESLint check..."
  bun run lint:check
  if [ $? -ne 0 ]; then
    echo "❌ Frontend lint check failed. Commit aborted."
    exit 1
  fi
  
  echo "✅ Frontend checks passed!"
  cd ..
  echo ""
fi

# Stage any formatted files
git add -A

echo "✅ All pre-commit checks passed!"
