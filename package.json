{
  "name": "xianze",
  "version": "1.0.0",
  "private": true,
  "description": "XIANZE Event Management System - Root workspace",
  "scripts": {
    "prepare": "husky install",
    "lint": "bun run lint --filter=./backend --filter=./frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "backend/**/*.{ts,js}": [
      "prettier --write"
    ],
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
