# XIANZE Production Environment
# Copy this file to .env on your production VPS
# IMPORTANT: Replace all placeholder values with actual secrets!

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server
NODE_ENV=production
BACKEND_PORT=5000
DOMAIN=xianze.tech
CORS_ORIGIN=https://xianze.tech

# Database (SQLite)
# Path is mounted via Docker volume in production
DATABASE_PATH=/data/xianze.db
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================
# AUTHENTICATION (REQUIRED - Use strong secrets!)
# ============================================
# Generate with: openssl rand -base64 32

JWT_SECRET=REPLACE_WITH_STRONG_SECRET
QR_HASH_SALT=REPLACE_WITH_STRONG_SALT

# ============================================
# MAIL CONFIGURATION (REQUIRED for event passes)
# ============================================
# IMPORTANT: MAIL_HOST must be 'mailserver' for Docker networking
# The mailserver container is accessible via its Docker service name

MAIL_HOST=mailserver
MAIL_PORT=587
MAIL_USER=contact@xianze.tech
MAIL_PASSWORD=REPLACE_WITH_MAIL_PASSWORD
MAIL_FROM=contact@xianze.tech
MAIL_FROM_NAME="Xianze Support"
MAIL_REPLY_TO=contact@xianze.tech
# Optional (improves deliverability)
# Example: <mailto:unsubscribe@xianze.tech>, <https://xianze.tech/unsubscribe>
MAIL_LIST_UNSUBSCRIBE=
# Example: List-Unsubscribe=One-Click
MAIL_LIST_UNSUBSCRIBE_POST=List-Unsubscribe=One-Click
# Optional (set true for port 465)
MAIL_SECURE=false

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# In production, API is proxied through nginx at /api
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/GObiBOjDxn5KTC2GVwCXXp
NEXT_PUBLIC_SITE_URL=https://xianze.tech

# WebSocket URL (optional). If using nginx proxy, you can omit this.
# NEXT_PUBLIC_WS_URL=wss://xianze.tech/buzzer
