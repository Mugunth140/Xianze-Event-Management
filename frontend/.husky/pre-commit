#!/bin/sh

# XIANZE Frontend Pre-commit Hook
# Runs format and lint checks before allowing commit

echo "🚀 Running pre-commit checks for frontend..."

# Navigate to frontend directory
if [ -d "frontend" ]; then
  cd frontend
fi

echo "🎨 Step 1/3: Formatting files..."
bun run format
if [ $? -ne 0 ]; then
  echo "❌ Formatting failed. Commit aborted."
  exit 1
fi

echo "🔍 Step 2/3: Running ESLint..."
bun run lint:check
if [ $? -ne 0 ]; then
  echo "❌ Lint check failed. Commit aborted."
  exit 1
fi

echo "📦 Step 3/3: Staging formatted files..."
git add -A

echo "✅ Frontend pre-commit checks passed!"
