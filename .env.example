# XIANZE Development Environment
# Copy this file to .env for local development
# For production, see .env.production.example

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server
NODE_ENV=development
BACKEND_PORT=5000
CORS_ORIGIN=http://localhost:3000

# Database (SQLite)
DATABASE_PATH=./data/xianze.db
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=true

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================
# AUTHENTICATION
# ============================================

JWT_SECRET=xianze-dev-secret-2026
QR_HASH_SALT=xianze2026-dev-qr-salt

# ============================================
# MAIL CONFIGURATION (Optional for development)
# ============================================
# In development, you can leave these as-is and emails will fail silently
# For testing emails locally, use a tool like Mailhog or Mailtrap

MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USER=dev@xianze.tech
MAIL_PASSWORD=dev
MAIL_FROM=dev@xianze.tech
MAIL_FROM_NAME="Xianze Support"
MAIL_REPLY_TO=dev@xianze.tech
# Optional (improves deliverability)
# Example: <mailto:unsubscribe@xianze.tech>, <https://xianze.tech/unsubscribe>
MAIL_LIST_UNSUBSCRIBE=
# Example: List-Unsubscribe=One-Click
MAIL_LIST_UNSUBSCRIBE_POST=List-Unsubscribe=One-Click
# Optional (set true for port 465)
MAIL_SECURE=false

# ============================================
# FRONTEND CONFIGURATION
# ============================================

NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/your-group-link
