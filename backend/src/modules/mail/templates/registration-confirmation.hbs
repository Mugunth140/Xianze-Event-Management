<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registration Received - XIANZE 2026</title>
    <!--[if mso]>
    <noscript>
      <xml>
        <o:OfficeDocumentSettings>
          <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
      </xml>
    </noscript>
    <![endif]-->
  </head>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f5f5f5;">
      <tr>
        <td align="center" style="padding: 40px 16px;">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 560px; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
            
            <!-- Header -->
            <tr>
              <td style="background: linear-gradient(135deg, #6D40D4 0%, #8B5CF6 100%); padding: 40px 24px; text-align: center;">
                <div style="font-size: 48px; margin-bottom: 12px;">🎉</div>
                <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;">
                  Registration Received!
                </h1>
                <p style="margin: 8px 0 0; color: #e8e0f7; font-size: 14px; font-weight: 400;">
                  XIANZE 2026 • Inter-College Technical Symposium
                </p>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 32px 24px;">
                <h2 style="margin: 0 0 16px; color: #1a1a1a; font-size: 20px; font-weight: 600;">
                  Hi {{name}},
                </h2>

                <p style="margin: 0 0 20px; color: #333333; font-size: 15px; line-height: 1.6;">
                  Thank you for registering for <strong style="color: #6D40D4;">{{event}}</strong> at XIANZE 2026! 
                  We've received your registration and payment details.
                </p>

                <!-- Status Card -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0;">
                  <tr>
                    <td style="background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%); border-radius: 12px; padding: 20px;">
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                        <tr>
                          <td width="50" valign="top">
                            <div style="font-size: 32px;">⏳</div>
                          </td>
                          <td valign="top">
                            <h3 style="margin: 0 0 8px; color: #92400E; font-size: 16px; font-weight: 600;">
                              Payment Verification in Progress
                            </h3>
                            <p style="margin: 0; color: #A16207; font-size: 14px; line-height: 1.5;">
                              Our team will verify your payment within <strong>8 hours</strong>. 
                              You'll receive your event pass via email once verified.
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- Registration Details -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0; background-color: #f8f5ff; border-radius: 12px; overflow: hidden;">
                  <tr>
                    <td style="padding: 20px;">
                      <h3 style="margin: 0 0 16px; color: #6D40D4; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                        Registration Details
                      </h3>
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                        <tr>
                          <td style="padding: 8px 0; border-bottom: 1px solid #E5E7EB;">
                            <span style="color: #6B7280; font-size: 13px;">Event</span>
                          </td>
                          <td style="padding: 8px 0; border-bottom: 1px solid #E5E7EB; text-align: right;">
                            <span style="color: #1a1a1a; font-size: 14px; font-weight: 600;">{{event}}</span>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0; border-bottom: 1px solid #E5E7EB;">
                            <span style="color: #6B7280; font-size: 13px;">College</span>
                          </td>
                          <td style="padding: 8px 0; border-bottom: 1px solid #E5E7EB; text-align: right;">
                            <span style="color: #1a1a1a; font-size: 14px; font-weight: 600;">{{college}}</span>
                          </td>
                        </tr>
                        <tr>
                          <td style="padding: 8px 0;">
                            <span style="color: #6B7280; font-size: 13px;">Transaction ID</span>
                          </td>
                          <td style="padding: 8px 0; text-align: right;">
                            <span style="color: #1a1a1a; font-size: 14px; font-weight: 600; font-family: monospace;">{{transactionId}}</span>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <!-- What's Next -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0;">
                  <tr>
                    <td style="background-color: #f3f0fa; border-left: 4px solid #6D40D4; padding: 16px 20px; border-radius: 0 8px 8px 0;">
                      <p style="margin: 0 0 8px; color: #6D40D4; font-size: 14px; font-weight: 600;">
                        What happens next?
                      </p>
                      <ul style="margin: 0; padding-left: 20px; color: #444444; font-size: 14px; line-height: 1.6;">
                        <li style="margin-bottom: 6px;">Our team will verify your payment screenshot</li>
                        <li style="margin-bottom: 6px;">You'll receive your <strong>Event Pass</strong> with a unique QR code</li>
                        <li>Show the QR code at the venue for check-in</li>
                      </ul>
                    </td>
                  </tr>
                </table>

                <!-- CTA Button -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 28px 0;">
                  <tr>
                    <td style="background: linear-gradient(135deg, #6D40D4 0%, #8B5CF6 100%); border-radius: 12px;">
                      <a href="https://xianze.tech/events" target="_blank" style="display: inline-block; padding: 16px 32px; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none;">
                        Explore All Events →
                      </a>
                    </td>
                  </tr>
                </table>

                <p style="margin: 24px 0 0; color: #6B7280; font-size: 13px; line-height: 1.5;">
                  Have questions? Contact us at <a href="mailto:support@xianze.tech" style="color: #6D40D4; text-decoration: none;">support@xianze.tech</a>
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color: #1a1a1a; padding: 24px; text-align: center;">
                <p style="margin: 0 0 8px; color: #ffffff; font-size: 16px; font-weight: 600;">
                  XIANZE 2026
                </p>
                <p style="margin: 0; color: #9CA3AF; font-size: 12px;">
                  Inter-College Technical Symposium
                </p>
                <p style="margin: 16px 0 0; color: #6B7280; font-size: 11px;">
                  © {{year}} Xianze. All rights reserved.
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
