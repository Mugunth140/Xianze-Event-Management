<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cash Registration Received - Xianze'26</title>
</head>

<body
  style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background-color: #f5f3ff; -webkit-font-smoothing: antialiased;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f5f3ff;">
    <tr>
      <td align="center" style="padding: 24px 16px;">

        <!-- Main Card -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width: 420px; background-color: #ffffff; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(109, 64, 212, 0.12);">

          <!-- Header -->
          <tr>
            <td style="background-color: #6D40D4; padding: 28px 20px; text-align: center;">
              <div style="font-size: 40px; margin-bottom: 8px;">✅</div>
              <h1 style="margin: 0; color: #ffffff; font-size: 22px; font-weight: 700;">
                Cash Registration Received
              </h1>
              <p style="margin: 6px 0 0; color: rgba(255,255,255,0.85); font-size: 13px;">
                Xianze'26 • Technical Symposium
              </p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 24px 20px;">

              <!-- Greeting -->
              <p style="margin: 0 0 16px; color: #1a1a1a; font-size: 17px; font-weight: 600;">
                Hi {{name}} 👋
              </p>

              <p style="margin: 0 0 16px; color: #4B5563; font-size: 14px; line-height: 1.6;">
                Thanks for registering for <strong style="color: #6D40D4;">{{event}}</strong>. We've received your details.
              </p>

              <!-- Cash Note -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="margin-bottom: 20px;">
                <tr>
                  <td style="background-color: #ECFDF3; border-radius: 12px; padding: 16px;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td width="36" valign="top">
                          <span style="font-size: 24px;">💵</span>
                        </td>
                        <td valign="top" style="padding-left: 12px;">
                          <p style="margin: 0 0 4px; color: #166534; font-size: 14px; font-weight: 600;">
                            Cash Payment Selected
                          </p>
                          <p style="margin: 0; color: #15803D; font-size: 13px; line-height: 1.5;">
                            Please pay the registration fee at the event venue to receive your event pass.
                          </p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Details Card -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="margin-bottom: 20px; background-color: #F9FAFB; border-radius: 12px;">
                <tr>
                  <td style="padding: 16px;">
                    <p
                      style="margin: 0 0 12px; color: #6D40D4; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">
                      Your Details
                    </p>

                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="padding: 6px 0; color: #6B7280; font-size: 13px;">Event</td>
                        <td style="padding: 6px 0; color: #1F2937; font-size: 13px; text-align: right;">{{event}}</td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0; color: #6B7280; font-size: 13px;">College</td>
                        <td style="padding: 6px 0; color: #1F2937; font-size: 13px; text-align: right;">{{college}}</td>
                      </tr>
                      <tr>
                        <td style="padding: 6px 0; color: #6B7280; font-size: 13px;">Payment Mode</td>
                        <td style="padding: 6px 0; color: #1F2937; font-size: 13px; text-align: right;">Cash</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- What's Next -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="margin-bottom: 24px;">
                <tr>
                  <td style="background-color: #F3F0FA; border-radius: 12px; padding: 16px;">
                    <p style="margin: 0 0 8px; color: #6D40D4; font-size: 13px; font-weight: 600;">
                      📋 What's Next?
                    </p>
                    <ul style="margin: 0; padding-left: 16px; color: #4B5563; font-size: 13px; line-height: 1.7;">
                      <li>Pay the registration fee at the event venue</li>
                      <li>Receive your event pass after payment</li>
                      <li>Show your pass for entry</li>
                    </ul>
                  </td>
                </tr>
              </table>

              <!-- CTA Button -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="center">
                    <a href="https://xianze.tech/events" target="_blank"
                      style="display: inline-block; background-color: #6D40D4; color: #ffffff; padding: 14px 28px; border-radius: 10px; font-size: 14px; font-weight: 600; text-decoration: none;">
                      Explore Events
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1F2937; padding: 20px; text-align: center;">
              <p style="margin: 0; color: #ffffff; font-size: 14px; font-weight: 600;">
                Xianze'26
              </p>
              <p style="margin: 4px 0 0; color: #9CA3AF; font-size: 11px;">
                Inter-College Technical Symposium
              </p>
              <p style="margin: 12px 0 0; color: #6B7280; font-size: 10px;">
                © {{year}} Xianze
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>
</body>

</html>
