<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Update - Xianze'26</title>
</head>

<body
  style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background-color: #FEF2F2; -webkit-font-smoothing: antialiased;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #FEF2F2;">
    <tr>
      <td align="center" style="padding: 24px 16px;">

        <!-- Main Card -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width: 400px; background-color: #ffffff; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 20px rgba(239, 68, 68, 0.12);">

          <!-- Header -->
          <tr>
            <td style="background-color: #DC2626; padding: 28px 20px; text-align: center;">
              <div style="font-size: 40px; margin-bottom: 8px;">⚠️</div>
              <h1 style="margin: 0; color: #ffffff; font-size: 22px; font-weight: 700;">
                Payment Not Verified
              </h1>
              <p style="margin: 6px 0 0; color: rgba(255,255,255,0.85); font-size: 13px;">
                Action Required
              </p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding: 24px 20px;">

              <!-- Greeting -->
              <p style="margin: 0 0 16px; color: #1a1a1a; font-size: 17px; font-weight: 600;">
                Hi {{name}},
              </p>

              <p style="margin: 0 0 20px; color: #4B5563; font-size: 14px; line-height: 1.6;">
                We couldn't verify your payment for <strong style="color: #6D40D4;">{{event}}</strong>.
              </p>

              <!-- Reason Card -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="margin-bottom: 20px;">
                <tr>
                  <td
                    style="background-color: #FEF2F2; border-left: 4px solid #DC2626; border-radius: 0 12px 12px 0; padding: 16px;">
                    <p
                      style="margin: 0 0 6px; color: #DC2626; font-size: 12px; font-weight: 600; text-transform: uppercase;">
                      Reason
                    </p>
                    <p style="margin: 0; color: #7F1D1D; font-size: 14px; line-height: 1.5;">
                      {{reason}}
                    </p>
                  </td>
                </tr>
              </table>

              <!-- What to do -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="margin-bottom: 24px;">
                <tr>
                  <td style="background-color: #F3F0FA; border-radius: 12px; padding: 16px;">
                    <p style="margin: 0 0 8px; color: #6D40D4; font-size: 13px; font-weight: 600;">
                      💡 What can you do?
                    </p>
                    <ul style="margin: 0; padding-left: 16px; color: #4B5563; font-size: 13px; line-height: 1.7;">
                      <li>Re-register with a clear payment screenshot</li>
                      <li>Ensure transaction ID is visible</li>
                      <li>Contact us if this is an error</li>
                    </ul>
                  </td>
                </tr>
              </table>

              <!-- CTA Buttons -->
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="margin-bottom: 16px;">
                <tr>
                  <td align="center">
                    <a href="https://xianze.tech/register" target="_blank"
                      style="display: block; background-color: #6D40D4; color: #ffffff; padding: 14px 28px; border-radius: 10px; font-size: 14px; font-weight: 600; text-decoration: none; text-align: center;">
                      Register Again
                    </a>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="center">
                    <a href="https://xianze.tech/contact" target="_blank"
                      style="display: block; background-color: #F3F4F6; color: #4B5563; padding: 14px 28px; border-radius: 10px; font-size: 14px; font-weight: 600; text-decoration: none; text-align: center;">
                      Contact Support
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #1F2937; padding: 20px; text-align: center;">
              <p style="margin: 0; color: #ffffff; font-size: 14px; font-weight: 600;">
                Xianze'26
              </p>
              <p style="margin: 4px 0 0; color: #9CA3AF; font-size: 11px;">
                Inter-College Technical Symposium
              </p>
              <p style="margin: 12px 0 0; color: #6B7280; font-size: 10px;">
                © {{year}} Xianze
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>
</body>

</html>