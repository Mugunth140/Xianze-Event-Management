<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Update - XIANZE 2026</title>
  </head>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f5f5f5;">
      <tr>
        <td align="center" style="padding: 40px 16px;">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 560px; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
            
            <!-- Header -->
            <tr>
              <td style="background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); padding: 40px 24px; text-align: center;">
                <div style="font-size: 48px; margin-bottom: 12px;">⚠️</div>
                <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;">
                  Payment Verification Update
                </h1>
                <p style="margin: 8px 0 0; color: #FEE2E2; font-size: 14px; font-weight: 400;">
                  XIANZE 2026
                </p>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 32px 24px;">
                <h2 style="margin: 0 0 16px; color: #1a1a1a; font-size: 20px; font-weight: 600;">
                  Hi {{name}},
                </h2>

                <p style="margin: 0 0 20px; color: #333333; font-size: 15px; line-height: 1.6;">
                  We were unable to verify your payment for <strong style="color: #6D40D4;">{{event}}</strong>.
                </p>

                <!-- Reason Card -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0;">
                  <tr>
                    <td style="background-color: #FEF2F2; border-left: 4px solid #EF4444; padding: 16px 20px; border-radius: 0 8px 8px 0;">
                      <p style="margin: 0 0 8px; color: #DC2626; font-size: 14px; font-weight: 600;">
                        Reason for rejection:
                      </p>
                      <p style="margin: 0; color: #7F1D1D; font-size: 14px; line-height: 1.5;">
                        {{reason}}
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Next Steps -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0;">
                  <tr>
                    <td style="background-color: #f3f0fa; border-left: 4px solid #6D40D4; padding: 16px 20px; border-radius: 0 8px 8px 0;">
                      <p style="margin: 0 0 8px; color: #6D40D4; font-size: 14px; font-weight: 600;">
                        What can you do?
                      </p>
                      <ul style="margin: 0; padding-left: 20px; color: #444444; font-size: 14px; line-height: 1.6;">
                        <li style="margin-bottom: 6px;">Re-register with a valid payment screenshot</li>
                        <li style="margin-bottom: 6px;">Make sure the transaction ID is clearly visible</li>
                        <li>Contact us if you believe this is an error</li>
                      </ul>
                    </td>
                  </tr>
                </table>

                <!-- CTA Button -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 28px 0;">
                  <tr>
                    <td style="background: linear-gradient(135deg, #6D40D4 0%, #8B5CF6 100%); border-radius: 12px;">
                      <a href="https://xianze.tech/register" target="_blank" style="display: inline-block; padding: 16px 32px; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none;">
                        Register Again →
                      </a>
                    </td>
                  </tr>
                </table>

                <p style="margin: 24px 0 0; color: #6B7280; font-size: 13px; line-height: 1.5;">
                  Need help? Contact us at <a href="mailto:support@xianze.tech" style="color: #6D40D4; text-decoration: none;">support@xianze.tech</a>
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color: #1a1a1a; padding: 24px; text-align: center;">
                <p style="margin: 0 0 8px; color: #ffffff; font-size: 16px; font-weight: 600;">
                  XIANZE 2026
                </p>
                <p style="margin: 0; color: #9CA3AF; font-size: 12px;">
                  Inter-College Technical Symposium
                </p>
                <p style="margin: 16px 0 0; color: #6B7280; font-size: 11px;">
                  © {{year}} Xianze. All rights reserved.
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
