<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your Event Pass - Xianze'26</title>
</head>

<body
  style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background-color: #f5f3ff; -webkit-font-smoothing: antialiased;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f5f3ff;">
    <tr>
      <td align="center" style="padding: 24px 16px;">

        <!-- Event Pass Card -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width: 380px; background-color: #6D40D4; border-radius: 24px; overflow: hidden; box-shadow: 0 12px 40px rgba(109, 64, 212, 0.35);">

          <!-- Top Section -->
          <tr>
            <td style="padding: 28px 24px 20px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td>
                    <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700; font-style: italic;">
                      Xianze
                    </h1>
                    <p
                      style="margin: 4px 0 0; color: rgba(255,255,255,0.7); font-size: 11px; text-transform: uppercase; letter-spacing: 2px;">
                      Event Pass
                    </p>
                  </td>
                  <td style="text-align: right;">
                    <span
                      style="display: inline-block; background: rgba(255,255,255,0.2); color: #ffffff; padding: 6px 12px; border-radius: 16px; font-size: 10px; font-weight: 600; text-transform: uppercase;">
                      Payment Verified ✓
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Separator -->
          <tr>
            <td style="padding: 0 12px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="border-top: 2px dashed rgba(255,255,255,0.3);"></td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Attendee Info -->
          <tr>
            <td style="padding: 20px 24px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td width="50%">
                    <p
                      style="margin: 0 0 2px; color: rgba(255,255,255,0.6); font-size: 10px; text-transform: uppercase; letter-spacing: 1px;">
                      Attendee
                    </p>
                    <p style="margin: 0; color: #ffffff; font-size: 18px; font-weight: 700;">
                      {{name}}
                    </p>
                  </td>
                  <td width="50%" style="text-align: right;">
                    <p
                      style="margin: 0 0 2px; color: rgba(255,255,255,0.6); font-size: 10px; text-transform: uppercase; letter-spacing: 1px;">
                      Event
                    </p>
                    <p style="margin: 0; color: #ffffff; font-size: 16px; font-weight: 600;">
                      {{event}}
                    </p>
                  </td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
                style="margin-top: 16px;">
                <tr>
                  <td width="100%">
                    <p
                      style="margin: 0 0 2px; color: rgba(255,255,255,0.6); font-size: 10px; text-transform: uppercase; letter-spacing: 1px;">
                      College
                    </p>
                    <p style="margin: 0; color: #ffffff; font-size: 14px;">
                      {{college}}
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- QR Code Section -->
          <tr>
            <td style="padding: 0 24px 24px;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="center" style="background: #ffffff; border-radius: 16px; padding: 20px;">
                    <img src="cid:qrcode" alt="QR Code" width="160" height="160" style="display: block;" />
                    <p style="margin: 12px 0 0; color: #6B7280; font-size: 12px;">
                      Scan at venue for check-in
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>

        <!-- Instructions Card -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width: 380px; margin-top: 20px; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
          <tr>
            <td style="padding: 20px;">
              <p style="margin: 0 0 10px; color: #6D40D4; font-size: 13px; font-weight: 600;">
                📋 Check-in Instructions
              </p>
              <ul style="margin: 0; padding-left: 16px; color: #4B5563; font-size: 13px; line-height: 1.7;">
                <li>Screenshot this QR code</li>
                <li>Arrive 15 mins early</li>
                <li>Carry valid college ID</li>
              </ul>
            </td>
          </tr>
        </table>

        <!-- Action Buttons -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width: 380px; margin-top: 20px;">
          <tr>
            <td align="center" style="padding-bottom: 12px;">
              <a href="https://xianze.tech/schedule" target="_blank"
                style="display: block; background-color: #6D40D4; color: #ffffff; padding: 14px 28px; border-radius: 12px; font-size: 14px; font-weight: 600; text-decoration: none; text-align: center; width: 100%; box-sizing: border-box;">
                View Schedule
              </a>
            </td>
          </tr>
          <tr>
            <td align="center">
              <a href="https://chat.whatsapp.com/YOUR_WHATSAPP_LINK" target="_blank"
                style="display: block; background-color: #25D366; color: #ffffff; padding: 14px 28px; border-radius: 12px; font-size: 14px; font-weight: 600; text-decoration: none; text-align: center; width: 100%; box-sizing: border-box;">
                Join WhatsApp Community
              </a>
            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width: 380px; margin-top: 24px;">
          <tr>
            <td align="center">
              <p style="margin: 0; color: #6B7280; font-size: 12px;">
                See you at the event! 🚀
              </p>
              <p style="margin: 8px 0 0; color: #9CA3AF; font-size: 10px;">
                © {{year}} Xianze
              </p>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>
</body>

</html>