<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your Event Pass - XIANZE 2026</title>
    <!--[if mso]>
    <noscript>
      <xml>
        <o:OfficeDocumentSettings>
          <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
      </xml>
    </noscript>
    <![endif]-->
  </head>
  <body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f5f5f5;">
      <tr>
        <td align="center" style="padding: 40px 16px;">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 560px; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
            
            <!-- Header -->
            <tr>
              <td style="background: linear-gradient(135deg, #10B981 0%, #059669 100%); padding: 40px 24px; text-align: center;">
                <div style="font-size: 48px; margin-bottom: 12px;">🎟️</div>
                <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;">
                  Payment Verified!
                </h1>
                <p style="margin: 8px 0 0; color: #D1FAE5; font-size: 14px; font-weight: 400;">
                  Your Event Pass is Ready
                </p>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style="padding: 32px 24px;">
                <h2 style="margin: 0 0 16px; color: #1a1a1a; font-size: 20px; font-weight: 600;">
                  Congratulations, {{name}}! 🎊
                </h2>

                <p style="margin: 0 0 24px; color: #333333; font-size: 15px; line-height: 1.6;">
                  Your payment has been verified. Below is your exclusive event pass for 
                  <strong style="color: #6D40D4;">{{event}}</strong> at XIANZE 2026.
                </p>

                <!-- Event Pass Card -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0;">
                  <tr>
                    <td style="background: linear-gradient(135deg, #1a1a1a 0%, #2D2D2D 100%); border-radius: 16px; overflow: hidden;">
                      
                      <!-- Pass Header -->
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                        <tr>
                          <td style="padding: 24px 24px 16px; border-bottom: 2px dashed #444444;">
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                              <tr>
                                <td>
                                  <p style="margin: 0; color: #9CA3AF; font-size: 11px; text-transform: uppercase; letter-spacing: 1px;">
                                    Event Pass
                                  </p>
                                  <h3 style="margin: 4px 0 0; color: #ffffff; font-size: 20px; font-weight: 700;">
                                    XIANZE 2026
                                  </h3>
                                </td>
                                <td style="text-align: right;">
                                  <div style="display: inline-block; background: linear-gradient(135deg, #6D40D4 0%, #8B5CF6 100%); padding: 8px 16px; border-radius: 20px;">
                                    <span style="color: #ffffff; font-size: 12px; font-weight: 600;">VERIFIED ✓</span>
                                  </div>
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>

                      <!-- Pass Body -->
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                        <tr>
                          <td style="padding: 24px;">
                            <!-- Attendee Info -->
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom: 20px;">
                              <tr>
                                <td width="50%">
                                  <p style="margin: 0 0 4px; color: #9CA3AF; font-size: 11px; text-transform: uppercase;">
                                    Attendee
                                  </p>
                                  <p style="margin: 0; color: #ffffff; font-size: 16px; font-weight: 600;">
                                    {{name}}
                                  </p>
                                </td>
                                <td width="50%">
                                  <p style="margin: 0 0 4px; color: #9CA3AF; font-size: 11px; text-transform: uppercase;">
                                    Event
                                  </p>
                                  <p style="margin: 0; color: #8B5CF6; font-size: 16px; font-weight: 600;">
                                    {{event}}
                                  </p>
                                </td>
                              </tr>
                            </table>

                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin-bottom: 20px;">
                              <tr>
                                <td width="50%">
                                  <p style="margin: 0 0 4px; color: #9CA3AF; font-size: 11px; text-transform: uppercase;">
                                    College
                                  </p>
                                  <p style="margin: 0; color: #ffffff; font-size: 14px;">
                                    {{college}}
                                  </p>
                                </td>
                                <td width="50%">
                                  <p style="margin: 0 0 4px; color: #9CA3AF; font-size: 11px; text-transform: uppercase;">
                                    Pass ID
                                  </p>
                                  <p style="margin: 0; color: #10B981; font-size: 14px; font-weight: 600; font-family: monospace;">
                                    {{passId}}
                                  </p>
                                </td>
                              </tr>
                            </table>

                            <!-- QR Code -->
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                              <tr>
                                <td align="center" style="padding: 20px; background-color: #ffffff; border-radius: 12px;">
                                  <img src="{{qrCodeDataUrl}}" alt="Event Pass QR Code" width="200" height="200" style="display: block; border: none;" />
                                  <p style="margin: 12px 0 0; color: #6B7280; font-size: 12px;">
                                    Scan this QR code at the venue for check-in
                                  </p>
                                </td>
                              </tr>
                            </table>
                          </td>
                        </tr>
                      </table>

                    </td>
                  </tr>
                </table>

                <!-- Instructions -->
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin: 24px 0;">
                  <tr>
                    <td style="background-color: #f3f0fa; border-left: 4px solid #6D40D4; padding: 16px 20px; border-radius: 0 8px 8px 0;">
                      <p style="margin: 0 0 8px; color: #6D40D4; font-size: 14px; font-weight: 600;">
                        📋 Important Instructions
                      </p>
                      <ul style="margin: 0; padding-left: 20px; color: #444444; font-size: 14px; line-height: 1.6;">
                        <li style="margin-bottom: 6px;">Save this email or take a screenshot of the QR code</li>
                        <li style="margin-bottom: 6px;">Arrive at the venue <strong>15 minutes early</strong></li>
                        <li style="margin-bottom: 6px;">Show this QR code at the registration desk</li>
                        <li>Carry a valid college ID for verification</li>
                      </ul>
                    </td>
                  </tr>
                </table>

                <!-- CTA Button -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 28px 0;">
                  <tr>
                    <td style="background: linear-gradient(135deg, #6D40D4 0%, #8B5CF6 100%); border-radius: 12px;">
                      <a href="https://xianze.tech/schedule" target="_blank" style="display: inline-block; padding: 16px 32px; color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none;">
                        View Event Schedule →
                      </a>
                    </td>
                  </tr>
                </table>

                <p style="margin: 24px 0 0; color: #6B7280; font-size: 13px; line-height: 1.5;">
                  See you at the event! 🚀
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="background-color: #1a1a1a; padding: 24px; text-align: center;">
                <p style="margin: 0 0 8px; color: #ffffff; font-size: 16px; font-weight: 600;">
                  XIANZE 2026
                </p>
                <p style="margin: 0; color: #9CA3AF; font-size: 12px;">
                  Inter-College Technical Symposium
                </p>
                <p style="margin: 16px 0 0; color: #6B7280; font-size: 11px;">
                  © {{year}} Xianze. All rights reserved.
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
