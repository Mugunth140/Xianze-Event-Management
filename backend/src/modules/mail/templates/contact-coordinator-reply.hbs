<html lang='en'>

  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Reply from XIANZE Team - XIANZE 2026</title>
    <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  </head>

  <body
    style='margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f5f5f5; -webkit-font-smoothing: antialiased;'
  >

    <table
      role='presentation'
      width='100%'
      cellspacing='0'
      cellpadding='0'
      border='0'
      style='background-color: #f5f5f5;'
    >
      <tr>
        <td align='center' style='padding: 40px 16px;'>

          <table
            role='presentation'
            width='100%'
            cellspacing='0'
            cellpadding='0'
            border='0'
            style='max-width: 560px; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08);'
          >

            <!-- Header -->
            <tr>
              <td style='background-color: #6D40D4; padding: 32px 24px; text-align: center;'>
                <h1 style='margin: 0; color: #ffffff; font-size: 24px; font-weight: 700;'>
                  XIANZE 2026
                </h1>
                <p style='margin: 8px 0 0; color: #e8e0f7; font-size: 14px; font-weight: 400;'>
                  Inter-College Technical Symposium
                </p>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style='padding: 32px 24px;'>
                <h2 style='margin: 0 0 16px; color: #1a1a1a; font-size: 20px; font-weight: 600;'>
                  Hi {{name}},
                </h2>

                <p style='margin: 0 0 20px; color: #333333; font-size: 15px; line-height: 1.6;'>
                  Thank you for contacting us. Our team has reviewed your inquiry and here's our response:
                </p>

                <!-- Original Message -->
                <table
                  role='presentation'
                  width='100%'
                  cellspacing='0'
                  cellpadding='0'
                  border='0'
                  style='margin: 24px 0 16px;'
                >
                  <tr>
                    <td
                      style='background-color: #f9f9f9; border-left: 3px solid #cccccc; padding: 16px 20px; border-radius: 0 8px 8px 0;'
                    >
                      <p
                        style='margin: 0 0 8px; color: #666666; font-size: 13px; font-weight: 600; text-transform: uppercase;'
                      >
                        Your Message
                      </p>
                      <p style='margin: 0; color: #444444; font-size: 14px; line-height: 1.5; white-space: pre-wrap;'>
                        {{originalMessage}}
                      </p>
                    </td>
                  </tr>
                </table>

                <!-- Team Reply -->
                <table
                  role='presentation'
                  width='100%'
                  cellspacing='0'
                  cellpadding='0'
                  border='0'
                  style='margin: 16px 0 24px;'
                >
                  <tr>
                    <td
                      style='background-color: #f3f0fa; border-left: 4px solid #6D40D4; padding: 16px 20px; border-radius: 0 8px 8px 0;'
                    >
                      <p
                        style='margin: 0 0 8px; color: #6D40D4; font-size: 13px; font-weight: 600; text-transform: uppercase;'
                      >
                        Our Response
                      </p>
                      <p style='margin: 0; color: #1a1a1a; font-size: 15px; line-height: 1.6; white-space: pre-wrap;'>
                        {{replyMessage}}
                      </p>
                    </td>
                  </tr>
                </table>

                <p style='margin: 0 0 16px; color: #555555; font-size: 14px; line-height: 1.5;'>
                  If you have any further questions, feel free to join our WhatsApp community for instant updates and direct communication with our team!
                </p>

                <!-- WhatsApp CTA Button -->
                <table
                  role='presentation'
                  cellspacing='0'
                  cellpadding='0'
                  border='0'
                  style='margin: 28px 0;'
                >
                  <tr>
                    <td style='border-radius: 8px; background-color: #25D366;'>
                      <a
                        href='https://chat.whatsapp.com/GObiBOjDxn5KTC2GVwCXXp'
                        target='_blank'
                        style='display: inline-block; padding: 14px 28px; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: 600;'
                      >
                        <img
                          src='https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg'
                          alt='WhatsApp'
                          width='20'
                          height='20'
                          style='display: inline-block; vertical-align: middle; margin-right: 8px;'
                        />
                        Join WhatsApp Community
                      </a>
                    </td>
                  </tr>
                </table>

                <!-- Secondary CTA Button -->
                <table
                  role='presentation'
                  cellspacing='0'
                  cellpadding='0'
                  border='0'
                  style='margin: 16px 0 28px;'
                >
                  <tr>
                    <td style='border-radius: 8px; background-color: #6D40D4;'>
                      <a
                        href='https://xianze.tech'
                        target='_blank'
                        style='display: inline-block; padding: 14px 28px; color: #ffffff; text-decoration: none; font-size: 14px; font-weight: 600;'
                      >
                        Visit Our Website
                      </a>
                    </td>
                  </tr>
                </table>

                <p style='margin: 24px 0 0; color: #555555; font-size: 14px; line-height: 1.5;'>
                  Best regards,<br />
                  <strong style='color: #1a1a1a;'>The XIANZE Team</strong><br />
                  <a href='mailto:contact@xianze.tech' style='color: #6D40D4; text-decoration: none;'>contact@xianze.tech</a>
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style='background-color: #1a1a1a; padding: 24px; text-align: center;'>
                <p style='margin: 0 0 8px; color: #cccccc; font-size: 13px;'>
                  Department of Software Systems and Computer Science (PG)
                  <br />
                  KGCAS, Coimbatore - 641035
                </p>
                <p style='margin: 0; color: #888888; font-size: 12px;'>
                  {{year}} XIANZE. All rights reserved.
                </p>
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>

</html>
