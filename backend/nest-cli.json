{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "plugins": [],
    "assets": [
      {
        "include": "modules/mail/templates/**/*.hbs",
        "watchAssets": true
      },
      {
        "include": "modules/events/buildathon/data/*.json",
        "watchAssets": true
      },
      {
        "include": "public/**/*",
        "watchAssets": true
      }
    ]
  }
}