# ================================
# XIANZE Backend Environment Variables
# ================================
# Copy this file to .env for local development
# DO NOT commit .env files to version control

# --------------------------------
# Server Configuration
# --------------------------------
NODE_ENV=development
PORT=5000

# --------------------------------
# Database Configuration
# --------------------------------
# Path where SQLite database file will be stored
# In Docker, this is mapped to a volume at /data
DATABASE_PATH=./data/xianze.db

# Enable TypeORM query logging (disable in production)
DATABASE_LOGGING=true

# Synchronize database schema with entities (disable in production)
DATABASE_SYNCHRONIZE=true
